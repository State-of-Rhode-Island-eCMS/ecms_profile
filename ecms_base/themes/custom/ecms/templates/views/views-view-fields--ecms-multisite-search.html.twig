{#
/**
 * @file
 * Renders each multisite search result row as an ecms:icon-card component.
 *
 * Fields used (configured in the view, url excluded from display):
 *   fields.title.content  - Title with link wrapper; stripped to plain text.
 *   fields.url.content    - Canonical item URL from the originating site.
 */
#}
{% if fields %}
  {{ include('ecms:icon-card', {
    icon: 'link-external',
    link_url: fields.url.content|striptags|trim,
    link_text: fields.title.content|striptags|trim,
  }, with_context = false) }}
{% endif %}
