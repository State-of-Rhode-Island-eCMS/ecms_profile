{#
  Canvas CTA Component

  Emits the theme's existing `.qh__btn` link markup. All visual styling
  lives in `assets/patterns/00-atoms/06-buttons/`.

  Props:
    text    - Button label (required)
    link    - URL (required)
    variant - primary | secondary | tertiary | accent | link | text (required)
    icon    - Optional `@icons` filename (no extension); renders left of label.
#}
{% set variant_classes = {
  primary:   'qh__btn',
  secondary: 'qh__btn qh__btn--secondary',
  tertiary:  'qh__btn qh__btn--tertiary',
  accent:    'qh__btn qh__btn--accent',
  link:      'canvas-cta--link',
  text:      'canvas-cta--text',
} %}

<a href="{{ link }}"{{ attributes.addClass(['canvas-cta', variant_classes[variant]|default('')]) }}>
  {% if variant == 'link' %}
    <span class="canvas-cta__label">{{ text }}</span>
    <span class="canvas-cta__icon qh__icon" aria-hidden="true">
      {% include '@icons/arrow-right.svg' %}
    </span>
  {% else %}
    {% if icon %}
      <span class="qh__btn__icon" aria-hidden="true">
        {% include '@icons/' ~ icon ~ '.svg' %}
      </span>
    {% endif %}
    {{ text }}
  {% endif %}
</a>
