{#
  Canvas Heading Component

  Emits the chosen heading element with the matching `.qh__h*` class.

  Props:
    text  - Heading text (required)
    level - h1 | h2 | h3 | h4 | h5 | h6 (required)
#}
{% set level_classes = {
  h1: 'qh__h1',
  h2: 'qh__h2',
  h3: 'qh__h3',
  h4: 'qh__h4',
  h5: 'qh__h5',
  h6: 'qh__h6',
} %}

<{{ level }}{{ attributes.addClass(['canvas-heading', level_classes[level]|default('qh__h2')]) }}>{{ text }}</{{ level }}>
