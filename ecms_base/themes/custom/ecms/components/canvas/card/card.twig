{#
  Canvas Card Component
  Themed card container with 1–3 columns of slottable content. Background
  applied via existing `qh__t__*` classes (same vocabulary as Dynamic
  Section). Cells collapse to a single column on narrow card widths via
  container queries (mirrors `_dynamic-section.scss`).

  Props:
    theme        - inherit | primary | primary-light | secondary | tertiary | coffee-milk
    column_count - 1 | 2 | 3
    show_divider - boolean; renders a vertical rule between adjacent columns
    show_border  - boolean; renders a 1px outer border using `currentColor`

  Slots:
    card_1..card_3 - one slot per possible column
#}

{# Enum → class lookups (never concatenate — canvas-sdc-AGENTS.md §6.5). #}
{% set theme_classes = {
  'white':         'canvas-card--white',
  'primary':       'qh__t__primary',
  'primary-light': 'qh__t__primary--light',
  'secondary':     'qh__t__secondary',
  'tertiary':      'qh__t__tertiary',
  'coffee-milk':   'qh__t__coffee-milk',
} %}

{% set columns_classes = {
  1: 'canvas-card--cols-1',
  2: 'canvas-card--cols-2',
  3: 'canvas-card--cols-3',
} %}

{% set card_classes = [
  'canvas-card',
  theme_classes[theme]|default(''),
  columns_classes[column_count]|default(''),
  show_divider ? 'canvas-card--with-divider' : '',
  show_border ? 'canvas-card--with-border' : '',
] %}

<div {{ attributes.addClass(card_classes) }}>
  <div class="canvas-card__grid">
    {% for c in 1..column_count %}
      <div class="canvas-card__cell">
        {% if block('card_' ~ c) is defined %}
          {{ block('card_' ~ c) }}
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>
